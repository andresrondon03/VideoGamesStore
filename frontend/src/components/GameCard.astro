---
import type { Videojuego } from "../lib/types";

interface Props {
  game: Videojuego;
}

const { game } = Astro.props;
---

<article class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
  <div class="mb-3 flex items-start justify-between gap-3">
    <h3 class="text-lg font-semibold text-slate-900">{game.titulo}</h3>
    <span class="rounded-full bg-fuchsia-100 px-2 py-1 text-xs font-semibold text-fuchsia-700">
      ${game.precioBase.toFixed(2)}
    </span>
  </div>
  <p class="mb-3 text-sm text-slate-600">{game.descripcion || "Sin descripcion disponible."}</p>
  <div class="mb-3 flex flex-wrap gap-2">
    {game.categorias?.map((categoria) => <span class="rounded-full bg-slate-100 px-2 py-1 text-xs text-slate-700">{categoria.nombre}</span>)}
  </div>
  <div class="mb-4 flex flex-wrap gap-2">
    {game.plataformas?.map((plataforma) => <span class="rounded-full bg-indigo-100 px-2 py-1 text-xs text-indigo-700">{plataforma.nombre}</span>)}
  </div>
  <div class="flex items-center justify-between text-sm">
    <span class={game.stock > 0 ? "text-emerald-600" : "text-rose-600"}>
      {game.stock > 0 ? `Stock: ${game.stock}` : "Agotado"}
    </span>
    <button
      class="rounded-md bg-fuchsia-600 px-3 py-2 text-xs font-semibold text-white hover:bg-fuchsia-500 disabled:cursor-not-allowed disabled:bg-slate-400"
      disabled={game.stock <= 0}
      data-add-to-cart={game.id}
    >
      Agregar
    </button>
  </div>
</article>
