---
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Login | TechZone Gaming" description="Inicia sesion para comprar y consultar pedidos.">
  <Navbar currentPath={Astro.url.pathname} />
  <main class="mx-auto w-full max-w-xl px-4 py-12">
    <h1 class="mb-6 text-3xl font-bold text-slate-900">Iniciar sesion</h1>
    <form id="login-form" class="space-y-4 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <div>
        <label for="email" class="mb-1 block text-sm text-slate-700">Correo</label>
        <input id="email" name="email" type="email" required class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-800 outline-none focus:border-fuchsia-500" />
      </div>
      <div>
        <label for="password" class="mb-1 block text-sm text-slate-700">Contrasena</label>
        <input id="password" name="password" type="password" required class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-800 outline-none focus:border-fuchsia-500" />
      </div>
      <button class="w-full rounded-md bg-fuchsia-600 px-4 py-2 font-semibold text-white hover:bg-fuchsia-500">Entrar</button>
      <p id="message" class="text-sm"></p>
    </form>
  </main>
</Layout>

<script>
  import { api } from "../lib/api";
  import { setToken } from "../lib/client-store";

  const form = document.querySelector<HTMLFormElement>("#login-form");
  const message = document.querySelector<HTMLParagraphElement>("#message");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form) return;
    const data = new FormData(form);
    const email = String(data.get("email") ?? "");
    const password = String(data.get("password") ?? "");

    try {
      const token = await api.auth.login({ email, password });
      setToken(token);
      if (message) {
        message.textContent = "Sesion iniciada correctamente.";
        message.className = "text-sm text-emerald-600";
      }
    } catch (error) {
      if (message) {
        message.textContent = error instanceof Error ? error.message : "Error al iniciar sesion.";
        message.className = "text-sm text-rose-600";
      }
    }
  });
</script>
