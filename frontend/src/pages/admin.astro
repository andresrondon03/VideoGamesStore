---
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Panel Admin | TechZone Gaming" description="Vista admin para inventario y resumen de pedidos.">
  <Navbar currentPath={Astro.url.pathname} />
  <main class="mx-auto w-full max-w-6xl px-4 py-12 text-slate-900">
    <h1 class="mb-1 text-4xl font-bold">Panel de Administración</h1>
    <p class="mb-8 text-slate-600">Gestiona el inventario completo de tu tienda tech</p>

    <div id="access-block" class="mb-8 hidden rounded-xl border border-rose-200 bg-rose-50 p-6 text-rose-700"></div>

    <section id="admin-content" class="space-y-6">
      <div class="grid gap-4 md:grid-cols-3">
        <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <p class="mb-3 text-xs font-medium text-slate-500">Total Productos</p>
          <p id="stat-total" class="text-3xl font-bold">0</p>
          <p class="text-xs text-slate-500">En stock</p>
        </article>
        <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <p class="mb-3 text-xs font-medium text-slate-500">Valor Inventario</p>
          <p id="stat-value" class="text-3xl font-bold">$0.00</p>
          <p class="text-xs text-slate-500">Valor total en catalogo</p>
        </article>
        <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <p class="mb-3 text-xs font-medium text-slate-500">Promociones Activas</p>
          <p id="stat-promos" class="text-3xl font-bold">0</p>
          <p class="text-xs text-slate-500">Productos en oferta visual</p>
        </article>
      </div>

      <button id="toggle-form" class="rounded-md bg-fuchsia-600 px-4 py-2 text-sm font-semibold text-white hover:bg-fuchsia-500">
        + Agregar Nuevo Producto
      </button>

      <section id="crud-form-wrapper" class="hidden rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 id="form-title" class="mb-4 text-xl font-semibold">Crear videojuego</h2>
        <form id="game-form" class="grid gap-4 md:grid-cols-2">
          <input id="game-id" type="hidden" />
          <div>
            <label for="titulo" class="mb-1 block text-sm">Titulo</label>
            <input id="titulo" required class="w-full rounded border border-slate-300 px-3 py-2 outline-none focus:border-fuchsia-500" />
          </div>
          <div>
            <label for="precio" class="mb-1 block text-sm">Precio</label>
            <input id="precio" type="number" min="0" step="0.01" required class="w-full rounded border border-slate-300 px-3 py-2 outline-none focus:border-fuchsia-500" />
          </div>
          <div>
            <label for="stock" class="mb-1 block text-sm">Stock</label>
            <input id="stock" type="number" min="0" required class="w-full rounded border border-slate-300 px-3 py-2 outline-none focus:border-fuchsia-500" />
          </div>
          <div>
            <label for="categoria" class="mb-1 block text-sm">Categoria</label>
            <select id="categoria" class="w-full rounded border border-slate-300 px-3 py-2 outline-none focus:border-fuchsia-500">
              <option value="">Selecciona una categoria</option>
            </select>
          </div>
          <div>
            <label for="plataforma" class="mb-1 block text-sm">Plataforma</label>
            <select id="plataforma" class="w-full rounded border border-slate-300 px-3 py-2 outline-none focus:border-fuchsia-500">
              <option value="">Selecciona una plataforma</option>
            </select>
          </div>
          <div class="md:col-span-2">
            <label for="descripcion" class="mb-1 block text-sm">Descripcion</label>
            <textarea id="descripcion" rows="3" class="w-full rounded border border-slate-300 px-3 py-2 outline-none focus:border-fuchsia-500"></textarea>
          </div>
          <div class="md:col-span-2 flex gap-3">
            <button id="submit-btn" type="submit" class="rounded bg-fuchsia-600 px-4 py-2 text-sm font-semibold text-white hover:bg-fuchsia-500">Guardar</button>
            <button id="cancel-edit" type="button" class="rounded border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Cancelar</button>
          </div>
        </form>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="mb-4 text-xl font-semibold">Inventario de Productos</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full text-left text-sm">
            <thead>
              <tr class="border-b border-slate-200 text-slate-600">
                <th class="px-3 py-2">Producto</th>
                <th class="px-3 py-2">Categoria</th>
                <th class="px-3 py-2">Precio</th>
                <th class="px-3 py-2">Stock</th>
                <th class="px-3 py-2 text-right">Acciones</th>
              </tr>
            </thead>
            <tbody id="inventory-body"></tbody>
          </table>
        </div>
      </section>
      <p id="message" class="text-sm"></p>
    </section>
  </main>
</Layout>

<script>
  import { api } from "../lib/api";
  import { getJwtRole, getToken } from "../lib/client-store";
  import type { Categoria, Plataforma, Videojuego } from "../lib/types";

  const token = getToken();
  const role = getJwtRole(token);

  const accessBlock = document.querySelector<HTMLDivElement>("#access-block");
  const adminContent = document.querySelector<HTMLElement>("#admin-content");
  const tableBody = document.querySelector<HTMLTableSectionElement>("#inventory-body");
  const message = document.querySelector<HTMLParagraphElement>("#message");
  const statTotal = document.querySelector<HTMLParagraphElement>("#stat-total");
  const statValue = document.querySelector<HTMLParagraphElement>("#stat-value");
  const statPromos = document.querySelector<HTMLParagraphElement>("#stat-promos");
  const toggleFormBtn = document.querySelector<HTMLButtonElement>("#toggle-form");
  const formWrapper = document.querySelector<HTMLElement>("#crud-form-wrapper");
  const formTitle = document.querySelector<HTMLHeadingElement>("#form-title");
  const gameForm = document.querySelector<HTMLFormElement>("#game-form");
  const cancelEditBtn = document.querySelector<HTMLButtonElement>("#cancel-edit");

  const idInput = document.querySelector<HTMLInputElement>("#game-id");
  const tituloInput = document.querySelector<HTMLInputElement>("#titulo");
  const precioInput = document.querySelector<HTMLInputElement>("#precio");
  const stockInput = document.querySelector<HTMLInputElement>("#stock");
  const categoriaInput = document.querySelector<HTMLSelectElement>("#categoria");
  const plataformaInput = document.querySelector<HTMLSelectElement>("#plataforma");
  const descripcionInput = document.querySelector<HTMLTextAreaElement>("#descripcion");

  let juegos: Videojuego[] = [];
  let categoriasCatalogo: Categoria[] = [];
  let plataformasCatalogo: Plataforma[] = [];

  function setMessage(text: string, tone: "ok" | "error" = "ok") {
    if (!message) return;
    message.textContent = text;
    message.className = tone === "ok" ? "text-sm text-emerald-600" : "text-sm text-rose-600";
  }

  function updateStats() {
    const totalProductos = juegos.length;
    const valorInventario = juegos.reduce((acc, juego) => acc + juego.precioBase * juego.stock, 0);
    const promociones = juegos.filter((juego) => juego.precioBase < 50).length;

    if (statTotal) statTotal.textContent = String(totalProductos);
    if (statValue) statValue.textContent = `$${valorInventario.toFixed(2)}`;
    if (statPromos) statPromos.textContent = String(promociones);
  }

  function refreshSelectOptions() {
    if (categoriaInput) {
      categoriaInput.innerHTML =
        `<option value="">Selecciona una categoria</option>` +
        categoriasCatalogo.map((c) => `<option value="${c.id ?? ""}">${c.nombre}</option>`).join("");
    }

    if (plataformaInput) {
      plataformaInput.innerHTML =
        `<option value="">Selecciona una plataforma</option>` +
        plataformasCatalogo.map((p) => `<option value="${p.id ?? ""}">${p.nombre}</option>`).join("");
    }
  }

  function extractCatalogMetadata() {
    const catMap = new Map<number, Categoria>();
    const platMap = new Map<number, Plataforma>();

    juegos.forEach((juego) => {
      (juego.categorias ?? []).forEach((cat) => {
        if (typeof cat.id === "number") catMap.set(cat.id, cat);
      });
      (juego.plataformas ?? []).forEach((plat) => {
        if (typeof plat.id === "number") platMap.set(plat.id, plat);
      });
    });

    categoriasCatalogo = Array.from(catMap.values());
    plataformasCatalogo = Array.from(platMap.values());
    refreshSelectOptions();
  }

  function renderTable() {
    if (!tableBody) return;
    tableBody.innerHTML = juegos
      .map(
        (juego) => `
          <tr class="border-b border-slate-100 text-slate-700">
            <td class="px-3 py-2">
              <p class="font-medium">${juego.titulo}</p>
              <p class="text-xs text-slate-500">${juego.descripcion ?? "Sin descripcion"}</p>
            </td>
            <td class="px-3 py-2">${juego.categorias?.[0]?.nombre ?? "Sin categoria"}</td>
            <td class="px-3 py-2">$${juego.precioBase.toFixed(2)}</td>
            <td class="px-3 py-2">
              <span class="rounded-full px-2 py-1 text-xs ${juego.stock > 0 ? "bg-emerald-100 text-emerald-700" : "bg-slate-200 text-slate-700"}">
                ${juego.stock > 0 ? "En stock" : "Sin stock"}
              </span>
            </td>
            <td class="px-3 py-2 text-right">
              <button class="mr-2 text-slate-600 hover:text-fuchsia-700" data-edit="${juego.id}" title="Editar">✎</button>
              <button class="text-rose-600 hover:text-rose-700" data-delete="${juego.id}" title="Eliminar">🗑</button>
            </td>
          </tr>
        `,
      )
      .join("");

    const editButtons = tableBody.querySelectorAll<HTMLButtonElement>("[data-edit]");
    const deleteButtons = tableBody.querySelectorAll<HTMLButtonElement>("[data-delete]");

    editButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = Number(btn.dataset.edit);
        const juego = juegos.find((item) => item.id === id);
        if (!juego || !idInput || !tituloInput || !precioInput || !stockInput || !categoriaInput || !plataformaInput || !descripcionInput) return;
        idInput.value = String(juego.id);
        tituloInput.value = juego.titulo;
        precioInput.value = String(juego.precioBase);
        stockInput.value = String(juego.stock);
        categoriaInput.value = String(juego.categorias?.[0]?.id ?? "");
        plataformaInput.value = String(juego.plataformas?.[0]?.id ?? "");
        descripcionInput.value = juego.descripcion ?? "";
        if (formTitle) formTitle.textContent = "Editar videojuego";
        formWrapper?.classList.remove("hidden");
      });
    });

    deleteButtons.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = Number(btn.dataset.delete);
        if (!id || !token) return;
        const confirmDelete = window.confirm("¿Seguro que deseas eliminar este videojuego?");
        if (!confirmDelete) return;
        try {
          await api.videojuegos.eliminar(token, id);
          await loadInventory();
          setMessage("Videojuego eliminado correctamente.");
        } catch (error) {
          setMessage(error instanceof Error ? error.message : "No se pudo eliminar el videojuego.", "error");
        }
      });
    });
  }

  function resetForm() {
    if (!gameForm || !idInput || !formTitle) return;
    gameForm.reset();
    idInput.value = "";
    formTitle.textContent = "Crear videojuego";
  }

  async function loadInventory() {
    try {
      juegos = await api.videojuegos.listar();
      extractCatalogMetadata();
      renderTable();
      updateStats();
    } catch (error) {
      setMessage(error instanceof Error ? error.message : "No se pudo cargar inventario.", "error");
    }
  }

  toggleFormBtn?.addEventListener("click", () => {
    formWrapper?.classList.toggle("hidden");
    if (!formWrapper?.classList.contains("hidden")) resetForm();
  });

  cancelEditBtn?.addEventListener("click", () => {
    resetForm();
    formWrapper?.classList.add("hidden");
  });

  gameForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!token || !idInput || !tituloInput || !precioInput || !stockInput || !categoriaInput || !plataformaInput || !descripcionInput) return;

    const categoriaId = Number(categoriaInput.value);
    const plataformaId = Number(plataformaInput.value);
    const payload = {
      titulo: tituloInput.value.trim(),
      descripcion: descripcionInput.value.trim(),
      precioBase: Number(precioInput.value),
      stock: Number(stockInput.value),
      categorias: Number.isFinite(categoriaId) && categoriaInput.value ? [{ id: categoriaId }] : [],
      plataformas: Number.isFinite(plataformaId) && plataformaInput.value ? [{ id: plataformaId }] : [],
    };

    try {
      const id = Number(idInput.value);
      if (id) {
        await api.videojuegos.actualizar(token, id, payload);
        setMessage("Videojuego actualizado correctamente.");
      } else {
        await api.videojuegos.crear(token, payload);
        setMessage("Videojuego creado correctamente.");
      }
      resetForm();
      formWrapper?.classList.add("hidden");
      await loadInventory();
    } catch (error) {
      setMessage(error instanceof Error ? error.message : "Error al guardar videojuego.", "error");
    }
  });

  if (!token || role !== "ADMIN") {
    if (adminContent) adminContent.classList.add("hidden");
    if (accessBlock) {
      accessBlock.classList.remove("hidden");
      accessBlock.textContent = "Acceso denegado. Este panel es solo para administradores.";
    }
  } else {
    loadInventory();
  }
</script>
